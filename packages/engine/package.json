{
  "name": "@spatial/engine",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Core analysis engine for Project Spatial.",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:csv": "tsx src/cli/import-csv.ts",
    "analyze:experiment": "tsx src/cli/analyze-experiment.ts",
    "experiment1": "tsx src/cli/run-experiment1.ts",
    "experiment1:gaps": "tsx src/cli/run-experiment1-gaps.ts",
    "corner5x5": "tsx src/cli/run-corner-5x5.ts",
    "benchmark": "tsx src/benchmark/run-benchmarks.ts",
    "benchmark:rolling-phase": "tsx src/benchmark/rolling-phase-benchmark.ts",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "dotenv": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.7",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
